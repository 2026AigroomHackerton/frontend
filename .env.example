# =============================================================================
# .env  (이 파일은 .gitignore 에 의해 절대 커밋되지 않는다)
# -----------------------------------------------------------------------------
# 실제 비밀값이 들어가는 파일. 절대로 깃/슬랙/이메일에 평문으로 공유하지 말 것.
# 새 팀원이 합류하면 .env.example 을 복사해서 본인 키로 채우게 한다.
# =============================================================================

# 앱 메타. (기존 값 유지)
APP_ENV=local
APP_NAME="AI Mobile Document Assistant API"
VITE_API_TARGET=https://frontend-pnyn.onrender.com
VITE_API_BASE_URL=https://frontend-pnyn.onrender.com

# OpenAI API key. https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# 사용할 텍스트 모델. 비용/품질 trade-off:
#   - gpt-4o-mini : 저렴/빠름, 해커톤 MVP 에 충분
#   - gpt-4o      : 더 나은 품질, 비용 ~10x
OPENAI_MODEL_TEXT=gpt-4o-mini

# Vision(이미지) OCR 용 모델. 4o-mini 도 vision 지원.
OPENAI_MODEL_VISION=gpt-4o-mini



VITE_OPENAI_API_KEY=sk-proj-your-key-here

VITE_OPENAI_MODEL_TEXT=gpt-4o-mini

# Kakao Developers JavaScript key for Kakao Talk Share.
# Register your service domain in Kakao Developers > App > Platform > Web.
VITE_KAKAO_JAVASCRIPT_KEY=c7b0cb8de2f5891f1af701f550b50e16
